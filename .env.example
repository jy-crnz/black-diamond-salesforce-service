# ==============================================================================
# 🚀 APP CORE CONFIGURATION
# ==============================================================================
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=5710
LOG_LEVEL=DEBUG

# Administrative Data Lifecycle Retention (in days)
CLEANUP_DAYS=7

# ==============================================================================
# 🔒 MICROSERVICE GATEWAY (HMAC SECURITY)
# ==============================================================================
# Master shared secret key used by the verify_hmac boundary interceptor
SECRET_KEY=your_global_hmac_shared_secret_here
HMAC_SIGNATURE_MAX_AGE=300

# ==============================================================================
# 📡 SALESFORCE CRM INTEGRATION (JWT OAUTH)
# ==============================================================================
# Use https://login.salesforce.com for Production/Dev Orgs, or https://test.salesforce.com for Sandboxes
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=v60.0

# Connected App Consumer Key & Integration Account
SF_CONSUMER_KEY=your_salesforce_connected_app_consumer_key_here
SF_USERNAME=your_salesforce_integration_user@yourdomain.com

# Local Path variant (used for local filesystem debugging)
SF_PRIVATE_KEY_PATH=certs/server.key

# Raw PEM Content variant (Injected directly by HashiCorp Vault in Staging/Prod)
SF_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----"

# ==============================================================================
# 📦 MINIO OBJECT STORAGE (RAW DATA LAKE ZONE)
# ==============================================================================
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=your_minio_root_user_here
MINIO_SECRET_KEY=your_minio_root_password_here
MINIO_BUCKET=glynac-raw-zone
MINIO_SECURE=false

# ==============================================================================
# 🎛️ APACHE KAFKA EVENT STREAM BROKER
# ==============================================================================
# Comma-separated list of broker endpoints (e.g., localhost:9092 or infrastructure IPs)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Data privacy interceptor control toggle
PII_MASKING_ENABLED=true